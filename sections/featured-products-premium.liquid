{% liquid
  assign source_mode = section.settings.source_mode | default: 'collection'
  assign products_to_show = section.settings.products_to_show | default: 4
  assign columns_desktop = section.settings.columns_desktop | default: 4
  assign columns_mobile = section.settings.columns_mobile | default: '1'
  assign image_ratio = section.settings.image_ratio | default: 'portrait'
  assign section_width = section.settings.section_width | default: 'page'
  assign enable_gradient_background = false

  if section.settings.enable_gradient_background == true
    assign enable_gradient_background = true
  endif
%}

<section
  class="
    zentra-featured-products
    zentra-featured-products-{{ section.id }}
    zentra-featured-products--{{ section_width }}
    {% if section.settings.enable_hover_effect %}zentra-featured-products--hover{% endif %}
  "
  style="
    --zf-bg: {{ section.settings.color_background | default: '#0B0B0B' }};
    {% if enable_gradient_background %}
      --zf-section-bg:
        radial-gradient(circle at 78% 18%, {{ section.settings.gradient_secondary_color | default: '#3A8DFF' | color_modify: 'alpha', 0.13 }}, transparent 38%),
        radial-gradient(circle at 22% 30%, {{ section.settings.gradient_tertiary_color | default: '#FF3FD8' | color_modify: 'alpha', 0.07 }}, transparent 36%),
        radial-gradient(circle at 50% 28%, {{ section.settings.gradient_tertiary_color | default: '#FF3FD8' | color_modify: 'alpha', 0.055 }}, transparent 42%),
        radial-gradient(circle at 50% 54%, {{ section.settings.gradient_secondary_color | default: '#3A8DFF' | color_modify: 'alpha', 0.045 }}, transparent 54%),
        radial-gradient(circle at 14% 88%, {{ section.settings.gradient_primary_color | default: '#FF2A2A' | color_modify: 'alpha', 0.035 }}, transparent 42%),
        radial-gradient(circle at 50% 62%, rgba(255, 255, 255, 0.04), transparent 64%),
        linear-gradient(180deg, {{ section.settings.color_background | default: '#0B0B0B' }} 0%, #080808 54%, {{ section.settings.color_background | default: '#0B0B0B' }} 100%),
        {{ section.settings.color_background | default: '#0B0B0B' }};
    {% else %}
      --zf-section-bg: {{ section.settings.color_background | default: '#0B0B0B' }};
    {% endif %}
    --zf-text: {{ section.settings.color_text | default: '#FFFFFF' }};
    --zf-muted: {{ section.settings.color_muted_text | default: '#B8B8B8' }};
    --zf-accent: {{ section.settings.color_accent | default: '#FF2A2A' }};
    --zf-card-bg: {{ section.settings.card_background | default: '#141414' }};
    --zf-card-border: {{ section.settings.card_border_color | default: '#2A2A2A' }};
    --zf-card-radius: {{ section.settings.card_radius | default: 18 }}px;
    --zf-padding-top: {{ section.settings.section_padding_top | default: 72 }}px;
    --zf-padding-bottom: {{ section.settings.section_padding_bottom | default: 72 }}px;
    --zf-columns-desktop: {{ columns_desktop }};
    --zf-columns-mobile: {{ columns_mobile }};
  "
>
  <div class="zentra-featured-products__inner">
    <div class="zentra-featured-products__header">
      {% if section.settings.eyebrow != blank %}
        <p class="zentra-featured-products__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="zentra-featured-products__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="zentra-featured-products__subheading">
          {{ section.settings.subheading | escape | newline_to_br }}
        </div>
      {% endif %}
    </div>

    <div class="zentra-featured-products__grid">
      {% if source_mode == 'collection' and section.settings.collection != blank %}
        {% for product in section.settings.collection.products limit: products_to_show %}
          {% liquid
            assign benefit_text = product.metafields.custom.benefit_text.value | default: product.metafields.custom.benefit.value
          %}
          {% render 'premium-product-card',
            product: product,
            benefit_text: benefit_text,
            button_label: section.settings.button_label,
            show_prices: section.settings.show_prices,
            show_benefit_line: section.settings.show_benefit_line,
            show_buttons: section.settings.show_buttons,
            image_ratio: image_ratio,
            block: null
          %}
        {% endfor %}
      {% elsif source_mode == 'manual' and section.blocks.size > 0 %}
        {% for block in section.blocks limit: products_to_show %}
          {% liquid
            assign product = block.settings.product
            assign cta_label = block.settings.custom_cta_label | default: section.settings.button_label
          %}
          {% render 'premium-product-card',
            product: product,
            benefit_text: block.settings.benefit_text,
            button_label: cta_label,
            show_prices: section.settings.show_prices,
            show_benefit_line: section.settings.show_benefit_line,
            show_buttons: section.settings.show_buttons,
            image_ratio: image_ratio,
            block: block
          %}
        {% endfor %}
      {% else %}
        {% for index in (1..4) %}
          {% render 'premium-product-card',
            product: blank,
            benefit_text: 'Built for long sessions',
            button_label: section.settings.button_label,
            show_prices: section.settings.show_prices,
            show_benefit_line: section.settings.show_benefit_line,
            show_buttons: section.settings.show_buttons,
            image_ratio: image_ratio,
            block: null
          %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.shop_all_label != blank and section.settings.shop_all_link != blank %}
      <div class="zentra-featured-products__footer">
        <a class="zentra-featured-products__shop-all" href="{{ section.settings.shop_all_link }}">
          {{ section.settings.shop_all_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .zentra-featured-products {
    background: var(--zf-section-bg);
    color: var(--zf-text);
    padding-block: var(--zf-padding-top) var(--zf-padding-bottom);
  }

  .zentra-featured-products__inner {
    width: min(100% - 32px, 1240px);
    margin-inline: auto;
  }

  .zentra-featured-products--full .zentra-featured-products__inner {
    width: min(100% - 32px, 1480px);
  }

  .zentra-featured-products__header {
    max-width: 760px;
    margin-block-end: 34px;
  }

  .zentra-featured-products__eyebrow {
    margin: 0 0 12px;
    color: var(--zf-accent);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    line-height: 1;
    text-transform: uppercase;
  }

  .zentra-featured-products__heading {
    margin: 0;
    color: var(--zf-text);
    font-size: clamp(2rem, 4vw, 4.25rem);
    font-weight: 750;
    letter-spacing: 0;
    line-height: 0.95;
  }

  .zentra-featured-products__subheading {
    max-width: 560px;
    margin-block-start: 16px;
    color: var(--zf-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .zentra-featured-products__grid {
    display: grid;
    grid-template-columns: repeat(var(--zf-columns-desktop), minmax(0, 1fr));
    gap: 24px;
  }

  .zentra-product-card {
    position: relative;
    display: flex;
    min-width: 0;
    flex-direction: column;
    overflow: hidden;
    padding: 18px;
    border: 1px solid var(--zf-card-border);
    border-radius: var(--zf-card-radius);
    background: var(--zf-card-bg);
    box-shadow: 0 18px 44px rgb(0 0 0 / 0.18);
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }

  .zentra-featured-products--hover .zentra-product-card:hover {
    border-color: var(--zf-accent);
    box-shadow:
      0 12px 30px rgba(255, 42, 42, 0.12),
      0 0 20px rgba(255, 42, 42, 0.08);
    transform: translateY(-8px);
  }

  .zentra-product-card__media {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: calc(var(--zf-card-radius) - 6px);
    background:
      radial-gradient(circle at 50% 20%, rgb(255 255 255 / 0.06), transparent 46%),
      #0f0f0f;
    text-decoration: none;
  }

  .zentra-product-card__media--square {
    aspect-ratio: 1 / 1;
  }

  .zentra-product-card__media--portrait {
    aspect-ratio: 4 / 5;
  }

  .zentra-product-card__media--landscape {
    aspect-ratio: 16 / 11;
  }

  .zentra-product-card__media--adapt {
    min-height: 260px;
  }

  .zentra-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      filter 0.4s ease,
      transform 0.4s ease;
  }

  .zentra-featured-products--hover .zentra-product-card:hover .zentra-product-card__image {
    filter: brightness(1.1) contrast(1.05);
    transform: scale(1.05);
  }

  .zentra-product-card__placeholder {
    display: grid;
    width: 100%;
    height: 100%;
    min-height: 260px;
    place-items: center;
    color: rgb(255 255 255 / 0.34);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .zentra-product-card__content {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 18px 4px 2px;
  }

  .zentra-product-card__title {
    margin: 0;
    color: var(--zf-text);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.3px;
    line-height: 1.25;
  }

  .zentra-product-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .zentra-product-card__title a::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .zentra-product-card__benefit {
    margin: 8px 0 0;
    color: var(--zf-muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .zentra-product-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-block-start: auto;
    padding-block-start: 20px;
  }

  .zentra-product-card__price {
    color: var(--zf-text);
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1;
  }

  .zentra-product-card__price .compare-at-price {
    margin-inline-end: 6px;
    color: var(--zf-muted);
    font-weight: 500;
    text-decoration: line-through;
  }

  .zentra-product-card__button,
  .zentra-featured-products__shop-all {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 16px;
    border: 1px solid var(--zf-card-border);
    border-radius: 8px;
    background: transparent;
    color: var(--zf-text);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
  }

  .zentra-product-card__button:hover,
  .zentra-featured-products__shop-all:hover {
    border-color: var(--zf-accent);
    background: var(--zf-accent);
    color: #ffffff;
    box-shadow: 0 0 12px rgba(255, 42, 42, 0.4);
  }

  .zentra-featured-products__footer {
    display: flex;
    justify-content: center;
    margin-block-start: 32px;
  }

  .zentra-featured-products__shop-all {
    min-width: 150px;
    min-height: 44px;
  }

  @media screen and (max-width: 989px) {
    .zentra-featured-products__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .zentra-featured-products {
      padding-block: calc(var(--zf-padding-top) * 0.68) calc(var(--zf-padding-bottom) * 0.72);
    }

    .zentra-featured-products__inner {
      width: min(100% - 24px, 1240px);
    }

    .zentra-featured-products__header {
      margin-block-end: 24px;
    }

    .zentra-featured-products__heading {
      font-size: clamp(2rem, 11vw, 3rem);
    }

    .zentra-featured-products__subheading {
      font-size: 0.95rem;
    }

    .zentra-featured-products__grid {
      grid-template-columns: repeat(var(--zf-columns-mobile), minmax(0, 1fr));
      gap: 18px;
    }

    .zentra-product-card {
      padding: 12px;
    }

    .zentra-product-card__media--adapt {
      min-height: 220px;
    }

    .zentra-product-card__content {
      padding-block-start: 14px;
    }

    .zentra-product-card__meta {
      align-items: stretch;
      flex-direction: column;
      gap: 12px;
    }

    .zentra-product-card__button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Featured products premium",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "ESSENTIAL SETUP GEAR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Optimize Your Setup"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to play longer and stay comfortable."
    },
    {
      "type": "select",
      "id": "source_mode",
      "label": "Source mode",
      "options": [
        {
          "value": "collection",
          "label": "Collection"
        },
        {
          "value": "manual",
          "label": "Manual products"
        }
      ],
      "default": "collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "options": [
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
