

{% liquid
  assign announcement_text = section.settings.announcement_text | default: 'Free shipping on orders over $75 &bull; Designed for serious gamers &bull; Play longer. Stay comfortable &bull; Optimize your setup' | strip
  assign separator_character = section.settings.separator_character | default: '&bull;' | strip
  assign enable_bar = section.settings.enable_bar
  assign enable_marquee = section.settings.enable_marquee
  assign link_url = section.settings.link_url

  if enable_bar == nil
    assign enable_bar = true
  endif

  if enable_marquee == nil
    assign enable_marquee = true
  endif

  if separator_character == blank
    assign separator_character = '&bull;'
  endif
%}

{% if enable_bar and announcement_text != blank %}
  <aside
    class="
      zentra-announcement-bar
      {% if enable_marquee %}zentra-announcement-bar--marquee{% else %}zentra-announcement-bar--static{% endif %}
      {% if section.settings.pause_on_hover %}zentra-announcement-bar--pause-hover{% endif %}
    "
    style="
      --announcement-bg: {{ section.settings.background_color | default: '#0B0B0B' }};
      --announcement-text: {{ section.settings.text_color | default: '#FFFFFF' }};
      --announcement-speed: {{ section.settings.speed_seconds | default: 20 }}s;
      --announcement-font-size-desktop: {{ section.settings.font_size_desktop | default: 13 }}px;
      --announcement-font-size-mobile: {{ section.settings.font_size_mobile | default: 12 }}px;
      --announcement-padding-y: {{ section.settings.bar_padding_y | default: 8 }}px;
      --announcement-letter-spacing: {{ section.settings.letter_spacing | default: 0.4 }}px;
      --announcement-font-weight: {{ section.settings.font_weight | default: '600' }};
      --announcement-text-transform: {{ section.settings.text_transform | default: 'none' }};
    "
    role="region"
    aria-label="Announcement"
  >
    {% if link_url != blank %}
      <a class="zentra-announcement-bar__link" href="{{ link_url }}" aria-label="{{ announcement_text | escape }}">
    {% else %}
      <div class="zentra-announcement-bar__link" aria-label="{{ announcement_text | escape }}">
    {% endif %}
      <span class="visually-hidden">{{ announcement_text }}</span>

      {% if enable_marquee %}
        <span class="zentra-announcement-bar__viewport" aria-hidden="true">
          <span class="zentra-announcement-bar__track">
            {% for group_index in (1..2) %}
              <span class="zentra-announcement-bar__group">
                {% for item_index in (1..8) %}
                  <span class="zentra-announcement-bar__item">
                    <span class="zentra-announcement-bar__text">{{ announcement_text }}</span>
                    {% if section.settings.show_separator %}
                      <span class="zentra-announcement-bar__separator">{{ separator_character }}</span>
                    {% endif %}
                  </span>
                {% endfor %}
              </span>
            {% endfor %}
          </span>
        </span>
      {% else %}
        <span class="zentra-announcement-bar__static-text" aria-hidden="true">
          {{ announcement_text }}
        </span>
      {% endif %}
    {% if link_url != blank %}
      </a>
    {% else %}
      </div>
    {% endif %}
  </aside>
{% endif %}

<style>
  #shopify-section-{{ section.id }} {
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .zentra-announcement-bar,
  #shopify-section-{{ section.id }} .zentra-announcement-bar * {
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .zentra-announcement-bar {
    display: block;
    max-width: 100%;
    max-height: calc((var(--announcement-padding-y) * 2) + var(--announcement-font-size-desktop) + 2px);
  }

  #shopify-section-{{ section.id }} .zentra-announcement-bar__link {
    min-width: 0;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .zentra-announcement-bar__viewport,
  #shopify-section-{{ section.id }} .zentra-announcement-bar__track,
  #shopify-section-{{ section.id }} .zentra-announcement-bar__group,
  #shopify-section-{{ section.id }} .zentra-announcement-bar__item {
    min-width: max-content;
  }

  .zentra-announcement-bar {
    display: block;
    width: 100%;
    overflow: hidden;
    background: var(--announcement-bg);
    color: var(--announcement-text);
    border-block-end: 1px solid rgb(255 255 255 / 0.08);
  }

  .zentra-announcement-bar__link {
    display: flex;
    align-items: center;
    width: 100%;
    min-height: calc((var(--announcement-padding-y) * 2) + var(--announcement-font-size-desktop));
    padding-block: var(--announcement-padding-y);
    color: inherit;
    text-decoration: none;
    overflow: hidden;
  }

  .zentra-announcement-bar__viewport {
    display: block;
    flex: 1 1 auto;
    min-width: 0;
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
  }

  .zentra-announcement-bar__track {
    display: flex;
    width: max-content;
    min-width: max-content;
    will-change: transform;
    animation: zentra-announcement-marquee var(--announcement-speed) linear infinite;
  }

  .zentra-announcement-bar__group,
  .zentra-announcement-bar__item {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    white-space: nowrap;
    min-width: max-content;
  }

  .zentra-announcement-bar__item {
    padding-inline: 18px;
  }

  .zentra-announcement-bar__text,
  .zentra-announcement-bar__static-text,
  .zentra-announcement-bar__separator {
    font-family: var(--font-subheading--family, var(--font-body--family));
    font-size: var(--announcement-font-size-desktop);
    font-weight: var(--announcement-font-weight);
    line-height: 1;
    letter-spacing: var(--announcement-letter-spacing);
    text-transform: var(--announcement-text-transform);
    white-space: nowrap;
  }

  .zentra-announcement-bar__separator {
    margin-inline-start: 18px;
    color: #ff2a2a;
    opacity: 0.9;
  }

  .zentra-announcement-bar--static .zentra-announcement-bar__link {
    justify-content: center;
    padding-inline: 16px;
    text-align: center;
  }

  .zentra-announcement-bar__static-text {
    overflow: hidden;
    max-width: 100%;
    text-overflow: ellipsis;
  }

  .zentra-announcement-bar--pause-hover:hover .zentra-announcement-bar__track,
  .zentra-announcement-bar--pause-hover:focus-within .zentra-announcement-bar__track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .zentra-announcement-bar__track {
      animation: none;
      transform: translate3d(0, 0, 0);
    }
  }

  @media screen and (max-width: 749px) {
    .zentra-announcement-bar__link {
      min-height: calc((var(--announcement-padding-y) * 2) + var(--announcement-font-size-mobile));
    }

    #shopify-section-{{ section.id }} .zentra-announcement-bar {
      max-height: calc((var(--announcement-padding-y) * 2) + var(--announcement-font-size-mobile) + 2px);
    }

    .zentra-announcement-bar__text,
    .zentra-announcement-bar__static-text,
    .zentra-announcement-bar__separator {
      font-size: var(--announcement-font-size-mobile);
    }

    .zentra-announcement-bar__item {
      padding-inline: 14px;
    }

    .zentra-announcement-bar__separator {
      margin-inline-start: 14px;
    }
  }

  @keyframes zentra-announcement-marquee {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }
</style>

{% schema %}
{
  "name": "Zentra marquee bar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_bar",
      "label": "Enable announcement bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_marquee",
      "label": "Enable marquee animation",
      "default": true
    },
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Free shipping on orders over $75 &bull; Designed for serious gamers &bull; Play longer. Stay comfortable &bull; Optimize your setup"
    },
    {
      "type": "range",
      "id": "speed_seconds",
      "label": "Marquee speed",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "s",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Optional link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0B0B0B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Desktop font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Mobile font size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "bar_padding_y",
      "label": "Vertical padding",
      "min": 5,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 2,
      "step": 0.1,
      "unit": "px",
      "default": 0.4
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator between repetitions",
      "default": true
    },
    {
      "type": "text",
      "id": "separator_character",
      "label": "Separator character",
      "default": "&bull;"
    }
  ],
  "presets": [
    {
      "name": "Zentra marquee bar"
    }
  ]
}
{% endschema %}
