{% liquid
  assign card_product = product
  assign product_url = '#'
  assign product_title = 'ZENTRA product'
  assign product_image = blank
  assign resolved_button_label = button_label | default: 'View product'
  assign ratio_class = image_ratio | default: 'portrait'

  if card_product != blank
    assign product_url = card_product.url
    assign product_title = card_product.title
    assign product_image = card_product.featured_media.preview_image | default: card_product.featured_image
  endif
%}

<article class="zentra-product-card" {% if block != blank %}{{ block.shopify_attributes }}{% endif %}>
  <a
    class="zentra-product-card__media zentra-product-card__media--{{ ratio_class }}"
    href="{{ product_url }}"
    aria-label="{{ product_title | escape }}"
  >
    {% if product_image != blank %}
      {{
        product_image
        | image_url: width: 900
        | image_tag:
          class: 'zentra-product-card__image',
          loading: 'lazy',
          sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
          widths: '320, 480, 640, 800, 900'
      }}
    {% else %}
      <span class="zentra-product-card__placeholder">Product image</span>
    {% endif %}
  </a>

  <div class="zentra-product-card__content">
    <h3 class="zentra-product-card__title">
      <a href="{{ product_url }}">{{ product_title }}</a>
    </h3>

    {% if show_benefit_line and benefit_text != blank %}
      <p class="zentra-product-card__benefit">{{ benefit_text }}</p>
    {% endif %}

    <div class="zentra-product-card__meta">
      {% if show_prices %}
        <div class="zentra-product-card__price">
          {% if card_product != blank %}
            {% render 'price', product_resource: card_product %}
          {% else %}
            <span class="price">{{ 9900 | money }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if show_buttons %}
        <a class="zentra-product-card__button" href="{{ product_url }}">
          {{ resolved_button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</article>
